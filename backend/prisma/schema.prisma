// Rec(2004)11 §26 – "The What" for votings. Permanently anonymous.
model Ballot {
  id         String   @id @default(uuid())
  votingId   String
  optionId   String
  ballotHash String   @unique
  tokenHashed    String?

  voting Voting       @relation(fields: [votingId], references: [id])
  option Option       @relation(fields: [optionId], references: [id])

  @@index([votingId])
}

model VotingResult {
  id           String   @id @default(uuid())
  votingId     String   @unique
  tally        Json
  totalBallots Int
  tallyHash    String
  sealedAt     DateTime @default(now())

  voting Voting @relation(fields: [votingId], references: [id])
}

// ─── SURVEY MODULE ────────────────────────────────────────────────────────────

model Survey {
  id          String    @id @default(uuid())
  title       String
  description String?
  creatorId   String
  creator     User      @relation("SurveyCreator", fields: [creatorId], references: [id])
  groupId     String
  group       Group     @relation(fields: [groupId], references: [id])

  isOpen      Boolean   @default(false)
  isFinalized Boolean   @default(false)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  startAt     DateTime?
  endAt       DateTime?
  finalizedAt DateTime?

  questions      SurveyQuestion[]
  participations SurveyParticipation[]
  surveyTokens   SurveyToken[]
  // auditLogs      AuditLog[]            @relation("SurveyLogs")
  result         SurveyResult?
}

model SurveyQuestion {
  id         String             @id @default(uuid())
  surveyId   String
  survey     Survey             @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  type       SurveyQuestionType
  text       String
  isRequired Boolean            @default(true)
  order      Int                @default(0)

  options      SurveyOption[]
  ballots      SurveyBallot[]
  freeforms    SurveyFreeformBallot[]
  choiceConfig SurveyChoiceConfig?
  scaleConfig  SurveyScaleConfig?

  @@index([surveyId])
}

model SurveyChoiceConfig {
  id            String         @id @default(uuid())
  questionId    String         @unique
  question      SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  allowOther    Boolean        @default(false)
  allowMultiple Boolean        @default(false)
  minChoices    Int?
  maxChoices    Int?
}

model SurveyScaleConfig {
  id         String         @id @default(uuid())
  questionId String         @unique
  question   SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  scaleMin   Int
  scaleMax   Int
  step       Int            @default(1)
}

model SurveyOption {
  id         String         @id @default(uuid())
  questionId String
  question   SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  order      Int            @default(0)
  isDynamic  Boolean        @default(false)

  ballots SurveyBallot[]

  @@index([questionId])
}

// Rec(2004)11 §26 – "The Who" for surveys.
model SurveyParticipation {
  id        String   @id @default(uuid())
  userId    String
  surveyId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  survey Survey @relation(fields: [surveyId], references: [id])

  @@unique([userId, surveyId])
}

// Rec(2004)11 §47 – Single-use token that decouples authentication from ballot casting.
model SurveyToken {
  id        String   @id @default(uuid())
  surveyId  String
  userId    String
  tokenHash String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  survey Survey @relation(fields: [surveyId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  ballots         SurveyBallot[]
  freeformBallots SurveyFreeformBallot[]

  @@unique([userId, surveyId])
}

// ANONYMITY INVARIANTS:
//   1. No userId field.
//   2. No createdAt — timing-attack prevention (mirrors Ballot).
//   3. ballotHash = SHA-256(surveyId ‖ questionId ‖ optionId ‖ clientNonce)
model SurveyBallot {
  id         String  @id @default(uuid())
  questionId String
  optionId   String
  ballotHash String  @unique
  tokenId    String?

  question SurveyQuestion @relation(fields: [questionId], references: [id])
  option   SurveyOption   @relation(fields: [optionId], references: [id])
  token    SurveyToken?   @relation(fields: [tokenId], references: [id])

  @@index([questionId])
  @@index([tokenId])
}

model SurveyFreeformBallot {
  id         String  @id @default(uuid())
  questionId String
  text       String
  ballotHash String  @unique
  tokenId    String?

  question SurveyQuestion @relation(fields: [questionId], references: [id])
  token    SurveyToken?   @relation(fields: [tokenId], references: [id])

  @@index([questionId])
  @@index([tokenId])
}

model SurveyResult {
  id             String   @id @default(uuid())
  surveyId       String   @unique
  tally          Json
  totalResponses Int
  tallyHash      String
  sealedAt     DateTime @default(now())

  survey Survey @relation(fields: [surveyId], references: [id])
}

