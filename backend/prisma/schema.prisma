generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum Role {
  USER
  ADMIN
}

enum GroupRole {
  OWNER
  ADMIN
  MEMBER
}

enum VotingType {
  STANDARD
  MULTIPLE_CHOICE
}

enum RandomizerType {
  NONE
  COIN_FLIP
  ROULETTE
  PLINKO
  SPINNER
  DICE_ROLL
}

// Models
model User {
  id              String           @id @default(uuid())
  role            Role             @default(USER)
  email           String           @unique
  password        String
  name            String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  groups          UserGroup[]
  createdGroups   Group[]          @relation("GroupCreator")
  votes           Vote[]
  surveyAnswers   SurveyAnswer[]
  refreshTokens   RefreshToken[]
}

model Group {
  id        String      @id @default(uuid())
  name      String
  creatorId String
  createdAt DateTime    @default(now())
  creator   User        @relation("GroupCreator", fields: [creatorId], references: [id])
  users     UserGroup[]
  votings   Voting[]
  surveys   Survey[]
}

model UserGroup {
  id      String    @id @default(uuid())
  userId  String
  groupId String
  role    GroupRole @default(MEMBER)
  user    User      @relation(fields: [userId], references: [id])
  group   Group     @relation(fields: [groupId], references: [id])

  @@unique([userId, groupId])
}

model Voting {
  id             String         @id @default(uuid())
  title          String
  type           VotingType     @default(STANDARD)
  randomizerType RandomizerType @default(NONE)
  isOpen         Boolean        @default(false)
  description    String?
  
  // Settings
  allowMultiple  Boolean        @default(false)
  minChoices     Int            @default(1)
  maxChoices     Int?
  
  createdAt      DateTime       @default(now())
  startAt        DateTime?
  endAt          DateTime?
  
  groupId        String
  group          Group          @relation(fields: [groupId], references: [id])
  
  options        Option[]
}

model Option {
  id       String @id @default(uuid())
  text     String
  votingId String
  voting   Voting @relation(fields: [votingId], references: [id], onDelete: Cascade)
  
  votes    Vote[]

  @@index([votingId])
}

model Vote {
  id        String   @id @default(uuid())
  userId    String
  optionId  String
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id])
  option    Option   @relation(fields: [optionId], references: [id], onDelete: Cascade)
  
  @@index([optionId])
  @@index([userId, optionId])
}

model Survey {
  id                   String    @id @default(uuid())
  title                String
  description          String?
  isOpen               Boolean   @default(false)
  showAggregateResults Boolean   @default(true)
  allowAnonymous       Boolean   @default(false)
  
  createdAt            DateTime  @default(now())
  startAt              DateTime?
  endAt                DateTime?
  
  groupId              String
  group                Group     @relation(fields: [groupId], references: [id])
  
  questions            Question[]
}

model Question {
  id            String   @id @default(uuid())
  surveyId      String
  survey        Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  
  text          String
  description   String?
  order         Int      @default(0)
  allowMultiple Boolean  @default(false)
  
  options       QuestionOption[]
  answers       SurveyAnswer[]

  @@index([surveyId])
}

model QuestionOption {
  id         String   @id @default(uuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  text       String
  answers    SurveyAnswer[]

  @@index([questionId])
}

model SurveyAnswer {
  id         String         @id @default(uuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id])
  
  questionId String
  question   Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  optionId   String
  option     QuestionOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  
  createdAt  DateTime       @default(now())
  
  @@index([questionId])
  @@index([userId, questionId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model AdminSecret {
  id            String   @id @default(uuid())
  secret_hashed String   @unique
  createdAt     DateTime @default(now())
  expiresAt     DateTime @default(dbgenerated("now() + interval '30 days'"))
  active        Boolean  @default(true)
}