generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
  AUDITOR
}

enum GroupRole {
  OWNER
  ADMIN
  MODERATOR
  MEMBER
}

enum VotingType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
}

enum SurveyQuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  SCALE
  FREEFORM
}

// Rec(2004)11 §52 – all administrative actions must be classifiable and enumerated.
enum AuditAction {
  // ── Auth ──────────────────────────────────────────────────────────────────
  USER_LOGIN
  USER_LOGOUT
  TOKEN_REFRESH
  // ── Account ───────────────────────────────────────────────────────────────
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  EMAIL_VERIFY_REQUESTED
  EMAIL_VERIFY_COMPLETED
  // ── Voting lifecycle ──────────────────────────────────────────────────────
  VOTING_CREATED
  VOTING_OPENED
  VOTING_CLOSED
  VOTING_FINALIZED
  VOTING_DELETED
  OPTION_ADDED
  OPTION_UPDATED
  OPTION_REMOVED
  // BALLOT_CAST: userId MUST be null in the AuditLog row — see model comment
  BALLOT_CAST
  VOTING_TOKEN_ISSUED
  VOTING_RESULT_SEALED
  // ── Survey lifecycle ──────────────────────────────────────────────────────
  SURVEY_CREATED
  SURVEY_OPENED
  SURVEY_CLOSED
  SURVEY_FINALIZED
  SURVEY_DELETED
  SURVEY_TOKEN_ISSUED
  // SURVEY_BALLOT_CAST: userId MUST be null in the AuditLog row
  SURVEY_BALLOT_CAST
  SURVEY_RESULT_SEALED
  // ── Admin ─────────────────────────────────────────────────────────────────
  USER_ROLE_CHANGED
  GROUP_CREATED
  GROUP_DELETED
  MEMBER_ADDED
  MEMBER_REMOVED
}

// ─── USER & GROUP ─────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(uuid())
  role            Role      @default(USER)
  email           String    @unique
  password        String
  name            String?
  isActive        Boolean   @default(true)
  isEmailVerified Boolean   @default(false)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // ── Groups ────────────────────────────────────────────────────────────────
  groups        UserGroup[]
  createdGroups Group[]     @relation("GroupCreator")

  // ── Voting ────────────────────────────────────────────────────────────────
  createdVotings Voting[]            @relation("VotingCreator")
  // Rec(2004)11 §26 – "who voted" stored separately from "what was voted"
  votings        VoteParticipation[]

  // ── Survey ────────────────────────────────────────────────────────────────
  createdSurveys Survey[]             @relation("SurveyCreator")
  surveys        SurveyParticipation[]

  // ── Tokens ────────────────────────────────────────────────────────────────
  refreshTokens           RefreshToken[]
  surveyTokens            SurveyToken[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
}

model Group {
  id        String    @id @default(uuid())
  name      String
  creatorId String
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  creator User      @relation("GroupCreator", fields: [creatorId], references: [id])
  users   UserGroup[]
  votings Voting[]
  surveys Survey[]
}

model UserGroup {
  id      String    @id @default(uuid())
  userId  String
  groupId String
  role    GroupRole @default(MEMBER)
  joinedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  group Group @relation(fields: [groupId], references: [id])

  @@unique([userId, groupId])
}

// ─── VOTING MODULE ────────────────────────────────────────────────────────────

model Voting {
  id          String     @id @default(uuid())
  creatorId   String
  creator     User       @relation("VotingCreator", fields: [creatorId], references: [id])
  groupId     String
  group       Group      @relation(fields: [groupId], references: [id])

  title            String
  description      String?
  type             VotingType @default(SINGLE_CHOICE)
  isFinalized      Boolean    @default(false)
  isOpen           Boolean    @default(false)
  deletedAt        DateTime?

  allowOther       Boolean  @default(false)
  minChoices       Int      @default(1)
  maxChoices       Int?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  startAt     DateTime?
  endAt       DateTime?
  finalizedAt DateTime?

  options         Option[]
  ballots         Ballot[]
  participations  VoteParticipation[]
  result          VotingResult?
}

model Option {
  id        String  @id @default(uuid())
  text      String
  votingId  String
  isDynamic Boolean @default(false)

  voting  Voting   @relation(fields: [votingId], references: [id], onDelete: Cascade)
  ballots Ballot[]

  @@index([votingId])
}

// Rec(2004)11 §26 – "The Who" for votings.
model VoteParticipation {
  id        String   @id @default(uuid())
  userId    String
  votingId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  voting Voting @relation(fields: [votingId], references: [id])

  @@unique([userId, votingId])
  @@index([votingId])
}

